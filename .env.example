# Configuración de Entorno - Copiar a .env y ajustar valores

# API Configuration
API_URL=https://api-resultadosloterias.com/api/results/
FECHA_DEFECTO=2023-02-01

# Lottery Configuration
FIND_LOTERY=ASTRO

# Model Training Configuration
ITERATIONS=1000
MIN_ACCURACY=0.7
MAX_TRAINING_LOGS=3

# Advanced ML Configuration
USE_ADVANCED_ML=false
ML_ALGORITHM=RandomForest
HYPERPARAMETER_SEARCH=random
SEARCH_ITERATIONS=20
CV_FOLDS=5
ENABLE_FEATURE_ENGINEERING=true

# Paths
MODELS_DIR=IA_models
DATA_DIR=data
LOGS_DIR=logs

# Logging
LOG_LEVEL=INFO

# Alert System Configuration
ALERT_ACCURACY_WARNING=0.6
ALERT_ACCURACY_CRITICAL=0.5
ALERT_F1_WARNING=0.55
ALERT_F1_CRITICAL=0.45

# Email Alerts (opcional)
ALERT_EMAIL_ENABLED=false
ALERT_SMTP_SERVER=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_EMAIL_SENDER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_RECIPIENTS=
